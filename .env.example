# ─── 빌드 후 이 파일을 .env 로 복사하고 값을 채운다 (.env 는 gitignore 됨) ───

# 1) Anthropic API 키 — console.anthropic.com 에서 발급
#    비어 있으면 AI 계층은 건너뛰고(장르=기타, 요약=제목) 파이프라인만 돈다.
ANTHROPIC_API_KEY=

# 2) PWA 로그인 패스코드 (원하는 비밀 문자열)
APP_PASSCODE=change-me

# 3) JWT 서명 비밀 (아무 긴 랜덤 문자열)
JWT_SECRET=change-me-to-a-long-random-string

# 4) VAPID 키 — `npm run vapid` 로 생성해서 여기에 붙여넣기
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ─── 선택 설정 (기본값 있음) ───
PORT=8787
# SQLite 파일 경로
DB_PATH=./data/briefing.sqlite
# 프론트(PWA) origin — CORS 허용용. 기본 vite dev 서버
WEB_ORIGIN=http://localhost:5173
# 스케줄러 타임존
TZ=Asia/Seoul
